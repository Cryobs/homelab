networks:
  {{ forgejo_network_name }}:
    external: true

services:
  server:
    image: codeberg.org/forgejo/forgejo:{{ forgejo_version }}
    container_name: forgejo
    environment:
      - USER_UID=1000
      - USER_GID=1000
      - FORGEJO__server__DOMAIN={{ forgejo_domain }}
      - FORGEJO__server__ROOT_URL={{ forgejo_root_url }}
      - FORGEJO__server__SSH_DOMAIN={{ forgejo_domain }}
      - FORGEJO__server__SSH_PORT={{ forgejo_ssh_port }}
      - FORGEJO__actions__ENABLED={{ forgejo_actions_enabled | lower }}
      - FORGEJO__webhook__ALLOWED_HOST_LIST=*
    restart: unless-stopped
    networks:
      - {{ forgejo_network_name }}
    volumes:
      - {{ forgejo_data_dir }}:/data
      - /etc/localtime:/etc/localtime:ro
    ports:
      - '{{ forgejo_http_port }}:3000'
      - '{{ forgejo_ssh_port }}:22'
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

  docker-in-docker:
    image: docker:dind
    container_name: forgejo_dind
    privileged: true
    command: ['dockerd', '-H', 'tcp://0.0.0.0:2375', '--tls=false']
    restart: unless-stopped
    networks:
      - {{ forgejo_network_name }}
    volumes:
      - {{ forgejo_data_dir }}/.cache:/var/lib/docker
