#!/usr/bin/env bash

echo "╔════════════════════════════════════════════════╗"
echo "║  System Information                            ║"
echo "╚════════════════════════════════════════════════╝"
echo ""

echo "Hostname: $(hostname)"

{% if ansible_distribution is defined %}
echo "OS: $(lsb_release -d | cut -f2)"
{% endif %}

echo "Kernel: $(uname -r)"
echo "Uptime: $(uptime -p)"
echo ""

echo "CPU: $(nproc) cores"
echo "RAM: $(free -h | awk '/^Mem:/ {print $2}')"

{% if external_disk_mount_point is defined %}
echo "Disk: $(df -h {{ external_disk_mount_point }} | awk 'NR==2 {print $2 " total, " $3 " used, " $4 " available"}')"
{% endif %}

echo ""

echo "Docker: $(docker --version 2>/dev/null || echo 'Not installed')"
echo "Containers running: $(docker ps -q 2>/dev/null | wc -l)"


